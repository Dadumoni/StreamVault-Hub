# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Task links for task-based downloader logic
TASK1_LINK="https://google.com?q=task1"
TASK2_LINK="https://google.com?q=task2"
TASK3_LINK="https://google.com?q=task3"

# MongoDB connection string for persistent storage of videos and downloads.
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority"

# Channel link for video unreachable redirect/support button.
CHANNEL_LINK="https://youtube.com"

# The deployment URL of the app to enable the auto-ping self-keepawake feature.
SELF_URL="https://your-app-name.koyeb.app"

# Time interval in minutes to auto-ping the server (default: 5 minutes)
PING_INTERVAL_MINUTES="5"


